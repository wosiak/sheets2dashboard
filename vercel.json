{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/apps/minafit/dist/assets/$1"
    },
    {
      "source": "/(dashboard\\.html|formulario\\.html|styles\\.css|sheets-api\\.js|engine\\.js|config\\.js|auth\\.js)",
      "destination": "/api/index.js"
    },
    {
      "source": "/",
      "destination": "/apps/minafit/dist/index.html"
    },
    {
      "source": "/((?!dashboard|formulario|styles\\.css|sheets-api|engine|config|auth|api/).*)",
      "destination": "/apps/minafit/dist/$1"
    }
  ]
}
