{
  "version": 2,
  "cleanUrls": true,
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "dashboard.html",
        "formulario.html",
        "styles.css",
        "sheets-api.js",
        "engine.js",
        "config.js",
        "auth.js",
        "database.json"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/apps/minafit/dist/assets/$1"
    },
    {
      "source": "/dashboard.html",
      "destination": "/api/index.js"
    },
    {
      "source": "/formulario.html",
      "destination": "/api/index.js"
    },
    {
      "source": "/styles.css",
      "destination": "/api/index.js"
    },
    {
      "source": "/sheets-api.js",
      "destination": "/api/index.js"
    },
    {
      "source": "/engine.js",
      "destination": "/api/index.js"
    },
    {
      "source": "/config.js",
      "destination": "/api/index.js"
    },
    {
      "source": "/auth.js",
      "destination": "/api/index.js"
    },
    {
      "source": "/",
      "destination": "/apps/minafit/dist/index.html"
    },
    {
      "source": "/((?!dashboard|formulario|styles\\.css|sheets-api|engine|config|auth|api/).*)",
      "destination": "/apps/minafit/dist/$1"
    }
  ]
}
